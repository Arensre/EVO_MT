import { useState } from "react";
import { Plus, Filter, Search, RotateCcw, User, X } from "lucide-react";
import { useMembersPermissions } from "../hooks/usePermissions";
import type { Member, MemberType } from "../types";

interface MemberListProps {
  members: Member[];
  memberTypes: MemberType[];
  selectedId?: number;
  onAddNew: () => void;
  onSelect: (member: Member) => void;
  onDelete: (member: Member) => void;
  onFilterChange?: (filters: { search?: string; memberTypeId?: number; isActive?: boolean }) => void;
  activeFilters?: { search?: string; member_type_id?: number; is_active?: boolean };
}

export function MemberList({
  members,
  memberTypes,
  selectedId,
  onAddNew,
  onSelect,
  onDelete,
  onFilterChange,
  activeFilters,
}: MemberListProps) {
  const { canRead, canWrite, canDelete } = useMembersPermissions();
  const [deleteConfirm, setDeleteConfirm] = useState<number | null>(null);
  const [showFilters, setShowFilters] = useState(false);
  const [search, setSearch] = useState(activeFilters?.search || "");
  const [memberTypeId, setMemberTypeId] = useState<number | "">(activeFilters?.member_type_id || "");
  const [isActive, setIsActive] = useState<boolean | "">(
    activeFilters?.is_active === undefined ? "" : activeFilters.is_active
  );

  const hasActiveFilters = activeFilters?.search || activeFilters?.member_type_id !== undefined || activeFilters?.is_active !== undefined;
  const shouldShowFilters = showFilters || hasActiveFilters;

  const applyFilters = () => {
    if (onFilterChange) {
      onFilterChange({
        search: search || undefined,
        memberTypeId: memberTypeId ? Number(memberTypeId) : undefined,
        isActive: isActive !== "" ? isActive : undefined,
      });
    }
  };

  const clearFilters = () => {
    setSearch("");
    setMemberTypeId("");
    setIsActive("");
    if (onFilterChange) {
      onFilterChange({});
    }
  };

  const getMemberTypeName = (id?: number) => {
    if (!id) return "";
    const type = memberTypes.find((t) => t.id === id);
    return type?.name || "";
  };

  // If no read permission, show message
  if (!canRead) {
    return (
      <div className="bg-white rounded-lg shadow p-8 text-center">
        <div className="text-gray-400 mb-4">
          <User size={48} className="mx-auto" />
        </div>
        <h3 className="text-lg font-medium text-gray-900 mb-2">Kein Zugriff</h3>
        <p className="text-gray-500">
          Sie haben keine Berechtigung, die Mitglieder zu sehen.
        </p>
      </div>
    );
  }

  return (
    <div className="h-full flex flex-col bg-gray-50">
      {/* Header */}
      <div className="bg-white border-b border-gray-200 p-6">
        <div className="flex justify-between items-center mb-4">
          <div>
            <h2 className="text-2xl font-bold text-gray-900">Mitglieder</h2>
            <p className="text-gray-500 mt-1">
              {members.length} Mitglieder
              {hasActiveFilters && " (gefiltert)"}
            </p>
          </div>

          <div className="flex items-center gap-2">
            <button
              onClick={() => setShowFilters(!showFilters)}
              className={`relative group p-3 rounded-lg transition-all duration-200 ${
                showFilters || hasActiveFilters
                  ? "bg-amber-100 text-amber-700 hover:bg-amber-200"
                  : "bg-gray-100 text-gray-600 hover:bg-gray-200"
              }`}
            >
              <Filter size={20} />
              <span className="absolute -bottom-8 left-1/2 transform -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50">
                Filter
              </span>
            </button>

            {canWrite && (
              <button
                onClick={onAddNew}
                className="relative group p-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-all duration-200"
              >
                <Plus size={20} />
                <span className="absolute -bottom-8 left-1/2 transform -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-50">
                  Neues Mitglied
                </span>
              </button>
            )}
          </div>
        </div>

        {shouldShowFilters && (
          <div className="bg-gray-50 rounded-lg p-4 border border-gray-200">
            <div className="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Suche
                </label>
                <input
                  type="text"
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  placeholder="Name, Mitgliedsnummer, E-Mail..."
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Mitgliedsart
                </label>
                <select
                  value={memberTypeId}
                  onChange={(e) =>
                    setMemberTypeId(e.target.value ? Number(e.target.value) : "")
                  }
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                >
                  <option value="">Alle Arten</option>
                  {memberTypes.map((type) => (
                    <option key={type.id} value={type.id}>
                      {type.name}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Status
                </label>
                <select
                  value={String(isActive)}
                  onChange={(e) =>
                    setIsActive(e.target.value === "" ? "" : e.target.value === "true")
                  }
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                >
                  <option value="">Alle Status</option>
                  <option value="true">Aktiv</option>
                  <option value="false">Inaktiv</option>
                </select>
              </div>

              <div className="flex items-center gap-2">
                <button
                  onClick={applyFilters}
                  className="flex items-center gap-2 px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition-colors"
                >
                  <Search size={18} />
                  Filtern
                </button>

                <button
                  onClick={clearFilters}
                  className="flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors"
                >
                  <RotateCcw size={18} />
                  Zurücksetzen
                </button>
              </div>
            </div>

            {hasActiveFilters && (
              <div className="mt-3 flex flex-wrap gap-2">
                {activeFilters?.search && (
                  <span className="inline-flex items-center gap-1 px-3 py-1 bg-amber-100 text-amber-800 text-sm rounded-full">
                    Suche: {activeFilters.search}
                    <button
                      onClick={() => {
                        setSearch("");
                        if (onFilterChange) {
                          onFilterChange({
                            search: undefined,
                            memberTypeId: activeFilters?.member_type_id,
                            isActive: activeFilters?.is_active,
                          });
                        }
                      }}
                      className="hover:text-amber-600 p-0.5"
                    >
                      <X size={14} />
                    </button>
                  </span>
                )}
                {activeFilters?.member_type_id !== undefined && (
                  <span className="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 text-blue-800 text-sm rounded-full">
                    Art: {getMemberTypeName(activeFilters.member_type_id)}
                    <button
                      onClick={() => {
                        setMemberTypeId("");
                        if (onFilterChange) {
                          onFilterChange({
                            search: activeFilters?.search,
                            memberTypeId: undefined,
                            isActive: activeFilters?.is_active,
                          });
                        }
                      }}
                      className="hover:text-blue-600 p-0.5"
                    >
                      <X size={14} />
                    </button>
                  </span>
                )}
                {activeFilters?.is_active !== undefined && (
                  <span className="inline-flex items-center gap-1 px-3 py-1 bg-green-100 text-green-800 text-sm rounded-full">
                    Status: {activeFilters.is_active ? "Aktiv" : "Inaktiv"}
                    <button
                      onClick={() => {
                        setIsActive("");
                        if (onFilterChange) {
                          onFilterChange({
                            search: activeFilters?.search,
                            memberTypeId: activeFilters?.member_type_id,
                            isActive: undefined,
                          });
                        }
                      }}
                      className="hover:text-green-600 p-0.5"
                    >
                      <X size={14} />
                    </button>
                  </span>
                )}
              </div>
            )}
          </div>
        )}
      </div>

      {/* Member List */}
      <div className="flex-1 overflow-auto">
        {members.length === 0 ? (
          <div className="bg-white rounded-lg shadow m-6">
            <div className="p-8 text-center text-gray-500">
              {hasActiveFilters
                ? "Keine Mitglieder gefunden."
                : "Keine Mitglieder vorhanden. Klicken Sie auf das + Symbol, um ein Mitglied anzulegen."}
            </div>
          </div>
        ) : (
          <div className="bg-white rounded-lg shadow m-6">
            <div className="divide-y divide-gray-200">
              {members.map((member) => {
                const isSelected = selectedId === member.id;
                const fullName = `${member.first_name} ${member.last_name}`;
                const memberTypeName = getMemberTypeName(member.member_type_id);
                return (
                  <div
                    key={member.id}
                    onClick={() => onSelect(member)}
                    className={`p-4 hover:bg-gray-50 transition-colors cursor-pointer flex items-center justify-between ${
                      isSelected ? "bg-blue-50 border-l-4 border-blue-500" : ""
                    }`}
                  >
                    <div className="flex items-center gap-4">
                      <div className="p-2 bg-gray-100 rounded-lg">
                        <User size={20} className="text-gray-600" />
                      </div>
                      <div>
                        <div className="flex items-center gap-2">
                          <span className="font-medium text-gray-900">{fullName}</span>
                          <span className="text-xs text-gray-400 font-mono bg-gray-100 px-2 py-0.5 rounded">
                            {member.member_number}
                          </span>
                          <span
                            className={`px-2 py-0.5 rounded text-xs ${
                              member.is_active
                                ? "bg-green-100 text-green-700"
                                : "bg-gray-100 text-gray-700"
                            }`}
                          >
                            {member.is_active ? "Aktiv" : "Inaktiv"}
                          </span>
                        </div>
                        <div className="text-sm text-gray-500 flex items-center gap-2">
                          {memberTypeName && (
                            <span className="px-2 py-0.5 bg-gray-100 rounded text-xs">
                              {memberTypeName}
                            </span>
                          )}
                          {member.city && <span>{member.city}</span>}
                          {member.email && (
                            <>
                              <span className="text-gray-400">•</span>
                              <span>{member.email}</span>
                            </>
                          )}
                        </div>
                      </div>
                    </div>

                    <div
                      className="flex items-center gap-2"
                      onClick={(e) => e.stopPropagation()}
                    >
                      {canDelete && (
                        <button
                          onClick={() => {
                            if (deleteConfirm === member.id) {
                              onDelete(member);
                              setDeleteConfirm(null);
                            } else {
                              setDeleteConfirm(member.id);
                            }
                          }}
                          className={`p-2 rounded transition-colors ${
                            deleteConfirm === member.id
                              ? "text-red-600 bg-red-50 hover:bg-red-100"
                              : "text-gray-500 hover:text-red-600 hover:bg-red-50"
                          }`}
                          title={
                            deleteConfirm === member.id ? "Klicken zum Löschen" : "Löschen"
                          }
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            strokeWidth="2"
                            strokeLinecap="round"
                            strokeLinejoin="round"
                          >
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                          </svg>
                        </button>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
